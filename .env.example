# Site URL for metadata + JSON-LD (production: https://angieskc.com).
NEXT_PUBLIC_SITE_URL=

# Admin photo uploads: https://angieskc.com/admin/photos
ADMIN_PHOTOS_PASSWORD=
# Optional; defaults to deriving from ADMIN_PHOTOS_PASSWORD if unset.
ADMIN_SESSION_SECRET=
# When set to "database", menu/locations/schedule load from Postgres if tables have rows (see admin Menu tab).
SITE_DATA_SOURCE=
# Postgres for admin catalog + photo metadata (Neon, Vercel Postgres, etc.).
DATABASE_URL=
# Public file storage for uploads (Vercel Blob read/write token).
BLOB_READ_WRITE_TOKEN=

# Menu: use Postgres relational catalog (import JSON from /admin → Menu, or `npm run import:menu`).
# Legacy `menu_items` table is still used when relational tables are empty and SITE_DATA_SOURCE=database.
# Google Sheet CSV for menu is no longer read by the app.

# Locations CSV — includes messageBoard column for Today's truck note.
LOCATIONS_CSV_URL=
NEXT_PUBLIC_LOCATIONS_CSV_URL=

# Upcoming schedule CSV.
SCHEDULE_CSV_URL=
NEXT_PUBLIC_SCHEDULE_CSV_URL=

# Browser/public Google Maps key (referrer-restricted). Used for embeds + client geocoding.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Optional server Geocoding API key (IP-restricted). Not required if client geocode is enough.
GOOGLE_MAPS_SERVER_KEY=
GOOGLE_MAPS_API_KEY=

# Clover (sandbox) — optional until live checkout.
NEXT_PUBLIC_CLOVER_PUBLIC_TOKEN_SANDBOX=
NEXT_PUBLIC_CLOVER_MERCHANT_ID_SANDBOX=
NEXT_PUBLIC_CLOVER_ENV=sandbox
